# SwiftFormat Configuration

--swiftversion 6.2
--indent 4
--allman false
--maxwidth 150
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--self init-only
--importgrouping alpha
--semicolons never
--commas inline
--trimwhitespace always
--stripunusedargs closure-only
--header strip

# SwiftLintのopening_braceルールと競合するため無効化
--disable wrapMultilineStatementBraces

# count(where:) は iOS 18+ 限定 API（デプロイ先 iOS 15）のため filter{}.count を維持
--disable preferCountWhere
